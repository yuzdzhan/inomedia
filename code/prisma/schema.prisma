generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── better-auth required tables ───────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  emailVerified   Boolean  @default(false)
  image           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Domain fields
  firstName       String   @default("")
  lastName        String   @default("")
  role            UserRole @default(employee)
  status          UserStatus @default(active)
  hourlyRateCents Int?
  deactivatedAt   DateTime?

  sessions        Session[]
  accounts        Account[]
  auditEvents     AuditEvent[] @relation("AuditActor")
  managedProjects Project[]    @relation("ProjectPrimaryManager")
  projectMemberships ProjectMember[]
  createdTasks    Task[]       @relation("TaskCreatedBy")
  taskComments    TaskComment[] @relation("TaskCommentAuthor")
  deletedTaskComments TaskComment[] @relation("TaskCommentDeletedBy")
  taskAssignments TaskAssignment[]
  uploadedTaskAttachments TaskAttachment[] @relation("TaskAttachmentUploader")
  taskTimeLogs    TaskTimeLog[]
  createdInvoices Invoice[]
  rateHistoryEntries UserRateHistory[]
  projectBillableRateOverrides ProjectMemberBillableRateOverride[]
  recordedPayments InvoicePayment[] @relation("InvoicePaymentRecordedBy")
  createdExpenses Expense[] @relation("ExpenseCreatedBy")
  paidExpenses    Expense[] @relation("ExpensePaidBy")
  createdRecurringTemplates RecurringExpenseTemplate[] @relation("RecurringTemplateCreatedBy")
  ledgerEntries   LedgerEntry[]    @relation("LedgerEntryCreatedBy")
  standaloneIncomes StandaloneIncome[] @relation("StandaloneIncomeCreatedBy")
  importedBankStatements BankStatement[] @relation("BankStatementImporter")

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ─── Domain tables ─────────────────────────────────────────────────────────

model Company {
  id                     String            @id @default(cuid())
  legalName              String
  eikBulstat             String            @unique
  vatNumber              String?
  registeredAddress      String
  molName                String
  defaultPaymentTermDays Int               @default(30)
  vatRegistered          Boolean           @default(true)
  vatRateBasisPoints     Int               @default(2000)
  currency               String            @default("EUR")
  timezone               String            @default("Europe/Sofia")
  invoiceNextNumber      Int               @default(1)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  clients                Client[]
  expenseCategories      ExpenseCategory[]
  expenses               Expense[]
  recurringTemplates     RecurringExpenseTemplate[]
  ownedTaskAttachments   TaskAttachment[] @relation("TaskAttachmentOwnerCompany")
  moneyContainers        MoneyContainer[]
  standaloneIncomes      StandaloneIncome[]
  bankStatements         BankStatement[]
}

model AuditEvent {
  id           String   @id @default(cuid())
  actorUserId  String?
  actor        User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  eventType    String
  entityType   String?
  entityId     String?
  oldValueJson Json?
  newValueJson Json?
  reason       String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@map("audit_event")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  manager
  employee
  accountant
}

enum UserStatus {
  active
  inactive
}

enum ClientStatus {
  active
  inactive
}

enum ProjectStatus {
  active
  on_hold
  completed
  cancelled
}

enum TaskStatus {
  todo
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskBillingType {
  hourly
  flat_fee
  non_billable
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
  paid
  overdue
  voided
}

enum ExpenseStatus {
  unpaid
  paid
}

enum PaymentMethod {
  bank_transfer
  cash
}

enum RecurringFrequency {
  monthly
  yearly
}

enum MoneyContainerType {
  bank
  cashbox
}

enum StatementRowMatchState {
  auto_matched
  needs_review
  unmatched
  irrelevant
}

enum LedgerEntryType {
  invoice_payment
  standalone_income
  expense_payment
  generic_credit
  generic_debit
  transfer_out
  transfer_in
}

model MoneyContainer {
  id                  String              @id @default(cuid())
  companyId           String
  company             Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  containerType       MoneyContainerType
  name                String
  openingBalanceCents Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  ledgerEntries       LedgerEntry[]
  standaloneIncomes   StandaloneIncome[]
  paidExpenses        Expense[]           @relation("ExpensePaidFromContainer")

  @@unique([companyId, containerType])
  @@map("money_container")
}

model LedgerEntry {
  id                  String            @id @default(cuid())
  containerId         String
  container           MoneyContainer    @relation(fields: [containerId], references: [id], onDelete: Restrict)
  entryType           LedgerEntryType
  amountCents         Int
  entryDate           DateTime          @db.Date
  description         String
  invoicePaymentId    String?           @unique
  invoicePayment      InvoicePayment?   @relation(fields: [invoicePaymentId], references: [id], onDelete: SetNull)
  standaloneIncomeId  String?           @unique
  standaloneIncome    StandaloneIncome? @relation(fields: [standaloneIncomeId], references: [id], onDelete: SetNull)
  expenseId           String?           @unique
  expense             Expense?          @relation("ExpenseLedgerEntry", fields: [expenseId], references: [id], onDelete: SetNull)
  transferPairId      String?
  createdByUserId     String
  createdByUser       User              @relation("LedgerEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt           DateTime          @default(now())

  @@index([containerId, entryDate])
  @@index([transferPairId])
  @@map("ledger_entry")
}

model StandaloneIncome {
  id                  String         @id @default(cuid())
  companyId           String
  company             Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  containerId         String
  container           MoneyContainer @relation(fields: [containerId], references: [id], onDelete: Restrict)
  description         String
  amountCents         Int
  incomeDate          DateTime       @db.Date
  notes               String?
  source              String?
  createdByUserId     String
  createdByUser       User           @relation("StandaloneIncomeCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  ledgerEntry         LedgerEntry?
  statementRows       BankStatementRow[]
  attachments         StandaloneIncomeAttachment[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([companyId, incomeDate])
  @@map("standalone_income")
}

model StandaloneIncomeAttachment {
  id                 String           @id @default(cuid())
  standaloneIncomeId String
  standaloneIncome   StandaloneIncome @relation(fields: [standaloneIncomeId], references: [id], onDelete: Cascade)
  originalFilename   String
  contentType        String
  sizeBytes          Int
  blob               Bytes
  createdAt          DateTime         @default(now())

  @@index([standaloneIncomeId])
  @@map("standalone_income_attachment")
}

model Client {
  id                String       @id @default(cuid())
  companyId         String
  company           Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  legalName         String
  registrationNumber String?
  vatNumber         String?
  billingAddress    String?
  mol               String?
  defaultPaymentTermDays Int?
  isInternal        Boolean      @default(false)
  isProtectedSystem Boolean      @default(false)
  status            ClientStatus @default(active)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  contacts          ClientContact[]
  projects          Project[]
  invoices          Invoice[]
  expenses          Expense[]
  recurringTemplates RecurringExpenseTemplate[]

  @@unique([companyId, legalName])
  @@map("client")
}

model ClientContact {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  email      String?
  phone      String?
  roleTitle  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("client_contact")
}

model Project {
  id                   String        @id @default(cuid())
  clientId             String
  client               Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  name                 String
  description          String?
  status               ProjectStatus @default(active)
  primaryManagerUserId String
  primaryManager       User          @relation("ProjectPrimaryManager", fields: [primaryManagerUserId], references: [id], onDelete: Restrict)
  budgetAmountCents    Int?
  retainerAmountCents  Int?
  isBillable           Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  members              ProjectMember[]
  taskLists            TaskList[]
  memberBillableRateOverrides ProjectMemberBillableRateOverride[]
  expenses             Expense[]
  recurringTemplates   RecurringExpenseTemplate[]

  @@unique([clientId, name])
  @@map("project")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@map("project_member")
}

model TaskList {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]

  @@unique([projectId, name])
  @@map("task_list")
}

model Task {
  id                 String          @id @default(cuid())
  taskListId         String
  taskList           TaskList        @relation(fields: [taskListId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  status             TaskStatus      @default(todo)
  priority           TaskPriority    @default(medium)
  deadlineDate       DateTime?       @db.Date
  billingType        TaskBillingType @default(hourly)
  flatFeeAmountCents Int?
  billableRateOverrideCents Int?
  createdByUserId    String
  createdByUser      User            @relation("TaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignees          TaskAssignment[]
  comments           TaskComment[]
  attachments        TaskAttachment[]
  timeLogs           TaskTimeLog[]
  invoiceSelections  InvoiceTaskSelection[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([taskListId, status])
  @@map("task")
}

model TaskComment {
  id              String   @id @default(cuid())
  taskId          String
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorUserId    String
  author          User     @relation("TaskCommentAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)
  body            String
  editedAt        DateTime?
  isDeleted       Boolean  @default(false)
  deletedAt       DateTime?
  deletedByUserId String?
  deletedByUser   User?    @relation("TaskCommentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: Restrict)
  attachments      TaskAttachment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([taskId, createdAt])
  @@index([authorUserId])
  @@index([deletedByUserId])
  @@map("task_comment")
}

model TaskAssignment {
  id        String   @id @default(cuid())
  taskId     String
  userId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignment")
}

model TaskAttachment {
  id                String       @id @default(cuid())
  ownerCompanyId    String
  ownerCompany      Company      @relation("TaskAttachmentOwnerCompany", fields: [ownerCompanyId], references: [id], onDelete: Cascade)
  taskId            String
  task              Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskCommentId     String?
  taskComment       TaskComment? @relation(fields: [taskCommentId], references: [id], onDelete: Cascade)
  uploadedByUserId  String
  uploadedByUser    User         @relation("TaskAttachmentUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  originalFilename  String
  contentType       String
  sizeBytes         Int
  blob              Bytes
  createdAt         DateTime     @default(now())

  @@index([ownerCompanyId, createdAt])
  @@index([taskId, createdAt])
  @@index([taskCommentId, createdAt])
  @@index([uploadedByUserId])
  @@map("task_attachment")
}

model TaskTimeLog {
  id               String   @id @default(cuid())
  taskId           String
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workDate         DateTime @db.Date
  description      String
  durationMinutes  Int
  startMinuteOfDay Int?
  endMinuteOfDay   Int?
  invoicedAt       DateTime?
  snapshotCostRateCents Int?
  snapshotBillableRateCents Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([taskId, workDate])
  @@index([userId, workDate])
  @@map("task_time_log")
}

model Invoice {
  id                    String            @id @default(cuid())
  clientId              String
  client                Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  status                InvoiceStatus     @default(draft)
  invoiceNumber         String?
  issueDate             DateTime?         @db.Date
  dueDate               DateTime?         @db.Date
  servicePeriodFrom     DateTime?         @db.Date
  servicePeriodTo       DateTime?         @db.Date
  paymentMethod         PaymentMethod     @default(bank_transfer)
  vatRateBasisPoints    Int               @default(2000)
  netTotalCents         Int               @default(0)
  vatTotalCents         Int               @default(0)
  grossTotalCents       Int               @default(0)
  paidTotalCents        Int               @default(0)
  isStaleDraft          Boolean           @default(false)
  lastUpdatedAt         DateTime          @default(now())
  issuedSnapshotJson    Json?
  issuedPdfFilename     String?
  issuedPdfContentType  String?
  issuedPdfBlob         Bytes?
  voidReason            String?
  createdByUserId       String
  createdByUser         User              @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  taskSelections        InvoiceTaskSelection[]
  payments              InvoicePayment[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([clientId, status, createdAt])
  @@index([createdByUserId, createdAt])
  @@map("invoice")
}

model InvoicePayment {
  id               String        @id @default(cuid())
  invoiceId        String
  invoice          Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amountCents      Int
  paymentDate      DateTime      @db.Date
  paymentMethod    PaymentMethod
  notes            String?
  recordedByUserId String
  recordedByUser   User          @relation("InvoicePaymentRecordedBy", fields: [recordedByUserId], references: [id], onDelete: Restrict)
  ledgerEntry      LedgerEntry?
  statementRows    BankStatementRow[]
  createdAt        DateTime      @default(now())

  @@index([invoiceId, paymentDate])
  @@map("invoice_payment")
}

model InvoiceTaskSelection {
  id                           String   @id @default(cuid())
  invoiceId                    String
  invoice                      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  taskId                       String
  task                         Task     @relation(fields: [taskId], references: [id], onDelete: Restrict)
  description                  String
  snapshotTakenAt              DateTime @default(now())
  hourlyUninvoicedValueCents   Int?
  flatFeeValueCents            Int?
  snapshotJson                 Json?
  createdAt                    DateTime @default(now())

  @@unique([invoiceId, taskId])
  @@index([taskId, createdAt])
  @@map("invoice_task_selection")
}

model UserRateHistory {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  effectiveFrom     DateTime @db.Date
  costRateCents     Int?
  billableRateCents Int?
  createdAt         DateTime @default(now())

  @@index([userId, effectiveFrom])
  @@map("user_rate_history")
}

model ProjectMemberBillableRateOverride {
  id                String   @id @default(cuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  effectiveFrom     DateTime @db.Date
  billableRateCents Int
  createdAt         DateTime @default(now())

  @@index([projectId, userId, effectiveFrom])
  @@map("project_member_billable_rate_override")
}

model ExpenseCategory {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expenses   Expense[]

  recurringTemplates RecurringExpenseTemplate[]

  @@unique([companyId, name])
  @@map("expense_category")
}

model Expense {
  id                  String          @id @default(cuid())
  companyId           String
  company             Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId          String
  category            ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  clientId            String?
  client              Client?         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId           String?
  project             Project?        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  description         String
  amountCents         Int
  incurredDate        DateTime        @db.Date
  status              ExpenseStatus   @default(unpaid)
  paidDate            DateTime?       @db.Date
  paidByUserId        String?
  paidByUser          User?           @relation("ExpensePaidBy", fields: [paidByUserId], references: [id], onDelete: Restrict)
  paidContainerId     String?
  paidContainer       MoneyContainer? @relation("ExpensePaidFromContainer", fields: [paidContainerId], references: [id], onDelete: SetNull)
  ledgerEntry         LedgerEntry?    @relation("ExpenseLedgerEntry")
  statementRows       BankStatementRow[]
  recurringTemplateId String?
  recurringTemplate   RecurringExpenseTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)
  isFromTemplate      Boolean         @default(false)
  attachments         ExpenseAttachment[]
  createdByUserId     String
  createdByUser       User            @relation("ExpenseCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([companyId, incurredDate])
  @@index([projectId, incurredDate])
  @@index([clientId, incurredDate])
  @@index([recurringTemplateId])
  @@map("expense")
}

model ExpenseAttachment {
  id               String   @id @default(cuid())
  expenseId        String
  expense          Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  originalFilename String
  contentType      String
  sizeBytes        Int
  blob             Bytes
  createdAt        DateTime @default(now())

  @@index([expenseId])
  @@map("expense_attachment")
}

model RecurringExpenseTemplate {
  id                  String             @id @default(cuid())
  companyId           String
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId          String
  category            ExpenseCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  clientId            String?
  client              Client?            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId           String?
  project             Project?           @relation(fields: [projectId], references: [id], onDelete: Restrict)
  description         String
  amountCents         Int
  frequency           RecurringFrequency
  startDate           DateTime           @db.Date
  endDate             DateTime?          @db.Date
  isActive            Boolean            @default(true)
  createdByUserId     String
  createdByUser       User               @relation("RecurringTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  occurrences         Expense[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([companyId, isActive])
  @@map("recurring_expense_template")
}

model BankStatement {
  id                  String        @id @default(cuid())
  companyId           String
  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  originalFilename    String
  contentType         String
  sizeBytes           Int
  fileBlob            Bytes
  importedAt          DateTime      @default(now())
  parsingVersion      String        @default("v1-csv")
  parseStatus         String        @default("ok")
  importedByUserId    String
  importedByUser      User          @relation("BankStatementImporter", fields: [importedByUserId], references: [id], onDelete: Restrict)
  rows                BankStatementRow[]
  createdAt           DateTime      @default(now())

  @@index([companyId, importedAt])
  @@map("bank_statement")
}

model BankStatementRow {
  id                  String                  @id @default(cuid())
  statementId         String
  statement           BankStatement           @relation(fields: [statementId], references: [id], onDelete: Cascade)
  rowIndex            Int
  transactionDate     DateTime                @db.Date
  description         String
  amountCents         Int
  matchState          StatementRowMatchState  @default(unmatched)
  invoicePaymentId    String?
  invoicePayment      InvoicePayment?         @relation(fields: [invoicePaymentId], references: [id], onDelete: SetNull)
  standaloneIncomeId  String?
  standaloneIncome    StandaloneIncome?       @relation(fields: [standaloneIncomeId], references: [id], onDelete: SetNull)
  expenseId           String?
  expense             Expense?                @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  reviewNote          String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([statementId, rowIndex])
  @@map("bank_statement_row")
}
