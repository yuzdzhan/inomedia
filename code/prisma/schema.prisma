generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── better-auth required tables ───────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  emailVerified   Boolean  @default(false)
  image           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Domain fields
  firstName       String   @default("")
  lastName        String   @default("")
  role            UserRole @default(employee)
  status          UserStatus @default(active)
  hourlyRateCents Int?
  deactivatedAt   DateTime?

  sessions        Session[]
  accounts        Account[]
  auditEvents     AuditEvent[] @relation("AuditActor")
  managedProjects Project[]    @relation("ProjectPrimaryManager")
  projectMemberships ProjectMember[]
  createdTasks    Task[]       @relation("TaskCreatedBy")
  taskComments    TaskComment[] @relation("TaskCommentAuthor")
  deletedTaskComments TaskComment[] @relation("TaskCommentDeletedBy")
  taskAssignments TaskAssignment[]
  uploadedTaskAttachments TaskAttachment[] @relation("TaskAttachmentUploader")
  taskTimeLogs    TaskTimeLog[]
  rateHistoryEntries UserRateHistory[]
  projectBillableRateOverrides ProjectMemberBillableRateOverride[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ─── Domain tables ─────────────────────────────────────────────────────────

model Company {
  id                     String            @id @default(cuid())
  legalName              String
  eikBulstat             String            @unique
  vatNumber              String?
  registeredAddress      String
  molName                String
  defaultPaymentTermDays Int               @default(30)
  vatRegistered          Boolean           @default(true)
  vatRateBasisPoints     Int               @default(2000)
  currency               String            @default("EUR")
  timezone               String            @default("Europe/Sofia")
  invoiceNextNumber      Int               @default(1)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  clients                Client[]
  expenseCategories      ExpenseCategory[]
  ownedTaskAttachments   TaskAttachment[] @relation("TaskAttachmentOwnerCompany")
}

model AuditEvent {
  id           String   @id @default(cuid())
  actorUserId  String?
  actor        User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  eventType    String
  entityType   String?
  entityId     String?
  oldValueJson Json?
  newValueJson Json?
  reason       String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@map("audit_event")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  manager
  employee
  accountant
}

enum UserStatus {
  active
  inactive
}

enum ClientStatus {
  active
  inactive
}

enum ProjectStatus {
  active
  on_hold
  completed
  cancelled
}

enum TaskStatus {
  todo
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskBillingType {
  hourly
  flat_fee
  non_billable
}

model Client {
  id                String       @id @default(cuid())
  companyId         String
  company           Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  legalName         String
  registrationNumber String?
  vatNumber         String?
  billingAddress    String?
  defaultPaymentTermDays Int?
  isInternal        Boolean      @default(false)
  isProtectedSystem Boolean      @default(false)
  status            ClientStatus @default(active)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  contacts          ClientContact[]
  projects          Project[]

  @@unique([companyId, legalName])
  @@map("client")
}

model ClientContact {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  email      String?
  phone      String?
  roleTitle  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("client_contact")
}

model Project {
  id                   String        @id @default(cuid())
  clientId             String
  client               Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  name                 String
  description          String?
  status               ProjectStatus @default(active)
  primaryManagerUserId String
  primaryManager       User          @relation("ProjectPrimaryManager", fields: [primaryManagerUserId], references: [id], onDelete: Restrict)
  budgetAmountCents    Int?
  retainerAmountCents  Int?
  isBillable           Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  members              ProjectMember[]
  taskLists            TaskList[]
  memberBillableRateOverrides ProjectMemberBillableRateOverride[]

  @@unique([clientId, name])
  @@map("project")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@map("project_member")
}

model TaskList {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]

  @@unique([projectId, name])
  @@map("task_list")
}

model Task {
  id                 String          @id @default(cuid())
  taskListId         String
  taskList           TaskList        @relation(fields: [taskListId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  status             TaskStatus      @default(todo)
  priority           TaskPriority    @default(medium)
  deadlineDate       DateTime?       @db.Date
  billingType        TaskBillingType @default(hourly)
  flatFeeAmountCents Int?
  billableRateOverrideCents Int?
  createdByUserId    String
  createdByUser      User            @relation("TaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignees          TaskAssignment[]
  comments           TaskComment[]
  attachments        TaskAttachment[]
  timeLogs           TaskTimeLog[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([taskListId, status])
  @@map("task")
}

model TaskComment {
  id              String   @id @default(cuid())
  taskId          String
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorUserId    String
  author          User     @relation("TaskCommentAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)
  body            String
  editedAt        DateTime?
  isDeleted       Boolean  @default(false)
  deletedAt       DateTime?
  deletedByUserId String?
  deletedByUser   User?    @relation("TaskCommentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: Restrict)
  attachments      TaskAttachment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([taskId, createdAt])
  @@index([authorUserId])
  @@index([deletedByUserId])
  @@map("task_comment")
}

model TaskAssignment {
  id        String   @id @default(cuid())
  taskId     String
  userId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignment")
}

model TaskAttachment {
  id                String       @id @default(cuid())
  ownerCompanyId    String
  ownerCompany      Company      @relation("TaskAttachmentOwnerCompany", fields: [ownerCompanyId], references: [id], onDelete: Cascade)
  taskId            String
  task              Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskCommentId     String?
  taskComment       TaskComment? @relation(fields: [taskCommentId], references: [id], onDelete: Cascade)
  uploadedByUserId  String
  uploadedByUser    User         @relation("TaskAttachmentUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  originalFilename  String
  contentType       String
  sizeBytes         Int
  blob              Bytes
  createdAt         DateTime     @default(now())

  @@index([ownerCompanyId, createdAt])
  @@index([taskId, createdAt])
  @@index([taskCommentId, createdAt])
  @@index([uploadedByUserId])
  @@map("task_attachment")
}

model TaskTimeLog {
  id               String   @id @default(cuid())
  taskId           String
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workDate         DateTime @db.Date
  description      String
  durationMinutes  Int
  startMinuteOfDay Int?
  endMinuteOfDay   Int?
  invoicedAt       DateTime?
  snapshotCostRateCents Int?
  snapshotBillableRateCents Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([taskId, workDate])
  @@index([userId, workDate])
  @@map("task_time_log")
}

model UserRateHistory {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  effectiveFrom     DateTime @db.Date
  costRateCents     Int?
  billableRateCents Int?
  createdAt         DateTime @default(now())

  @@index([userId, effectiveFrom])
  @@map("user_rate_history")
}

model ProjectMemberBillableRateOverride {
  id                String   @id @default(cuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  effectiveFrom     DateTime @db.Date
  billableRateCents Int
  createdAt         DateTime @default(now())

  @@index([projectId, userId, effectiveFrom])
  @@map("project_member_billable_rate_override")
}

model ExpenseCategory {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, name])
  @@map("expense_category")
}
